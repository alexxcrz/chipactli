# Variables de Entorno (Opcional)

# Entorno de ejecución
NODE_ENV=production

# Token de administrador para backups/importacion
# Genera uno largo y guardalo solo en tu hosting
# ADMIN_TOKEN=tu_token_seguro

# Secretos obligatorios en producción
# JWT_SECRET=
# TIENDA_JWT_SECRET=

# Orígenes permitidos para CORS (separados por coma)
# CORS_ALLOWED_ORIGINS=https://tu-frontend.onrender.com,https://tu-dominio.com

# URLs públicas obligatorias en Render
# FRONTEND_URL=https://tu-frontend.onrender.com
# PUBLIC_APP_URL=https://tu-app.onrender.com
# APP_BASE_URL=https://tu-app.onrender.com

# Alertas de seguridad por webhook
# SECURITY_ALERT_WEBHOOK_URL=https://hooks.slack.com/services/...
# SECURITY_ALERT_MIN_LEVEL=error
# SECURITY_ALERT_COOLDOWN_SEC=300

# Smoke tests externos
# SECURITY_SMOKE_BASE_URL=https://tu-app.onrender.com

# Puerto (se asigna automáticamente en producción)
# PORT=3001
