# Mercado Pago
MP_ACCESS_TOKEN=APP_USR-REEMPLAZA_CON_TU_ACCESS_TOKEN

# URLs de retorno (ajusta según tu dominio)
MP_SUCCESS_URL=http://127.0.0.1:3000/
MP_PENDING_URL=http://127.0.0.1:3000/
MP_FAILURE_URL=http://127.0.0.1:3000/

# Opcional: URL base pública si luego agregas webhook
# APP_BASE_URL=https://tu-dominio.com

# Correo transaccional (Gmail SMTP)
# Recomendado: crear contraseña de aplicación en tu cuenta de Google.
MAIL_ENABLED=1
SMTP_HOST=smtp.gmail.com
SMTP_PORT=465
SMTP_SECURE=1
SMTP_USER=chipactli.ventas@gmail.com
SMTP_PASS=tu_app_password_de_google
SMTP_FROM="CHIPACTLI Ventas <chipactli.ventas@gmail.com>"
# URL publica del logo que quieres mostrar en los correos (PNG/SVG/JPG)
MAIL_LOGO_URL=https://tu-dominio.com/images/logo.png
